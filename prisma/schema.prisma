generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum StudentStatus {
  ACTIVE
  INACTIVE
  BLOCKED
}

enum AdminRole {
  SYSTEM_ADMIN
  TEACHER
}

model Admin {
  id String @id @default(cuid())

  fullName     String
  profileImage String?
  email        String  @unique
  phone        String? @unique
  designation  String?
  verifyToken  String?

  password String

  role AdminRole

  isActive      Boolean @default(true)
  isVerified    Boolean @default(false)
  emailVerifyed Boolean @default(false)

  // Organization
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Soft Delete
  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  mentorRequests MentorRequest[]

  @@index([organizationId])
  @@index([role])
}

model Organization {
  id String @id @default(cuid())

  name  String
  email String? @unique
  phone String?

  website String?
  logo    String?

  description String? @db.Text
  isVerified  Boolean @default(false)

  // Relations
  admins  Admin[]
  address Address?

  hiringEvents Job[]

  // Soft Delete
  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SocialLink {
  id        String  @id @default(cuid())
  platform  String
  url       String
  studentId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model Student {
  id String @id @default(cuid())

  // Basic Information
  fullName    String
  email       String    @unique
  phone       String?   @unique
  password    String?
  dateOfBirth DateTime?
  gender      Gender?
  verifyToken String?

  // Profile
  headline     String? // Full Stack Developer
  bio          String? @db.Text
  profileImage String?
  resumeUrl    String?

  educations  Education[]
  socialLinks SocialLink[]
  skills      String[]

  savedJobs SavedJob[]

  nccProfile             NccProfile?
  physicalMedicalProfile PhysicalMedicalProfile?

  // Job Preferences
  preferredRole     String?
  preferredLocation String[]

  expectedSalary    Int?
  willingToRelocate Boolean @default(false)
  openToRemote      Boolean @default(true)

  // Account
  status           StudentStatus @default(ACTIVE)
  profileCompleted Boolean       @default(false)
  profileScore     Int           @default(0)

  // Verification
  emailVerified Boolean @default(false)
  phoneVerified Boolean @default(false)

  // Soft Delete
  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  mentorRequests MentorRequest[]

  // Audit
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  addresses Address[]
}

model NccProfile {
  id String @id @default(cuid())

  fullName        String
  FatherFullName  String
  MotherFullName  String
  photo           String
  dateOfBirth     String
  aadharNo        String?
  aadhar          String?
  nccDirector     String
  nccGroupHQ      String
  enrolmentNumber String
  nccBattalion    String
  nccUnit         String
  nccCirtificate  String?
  nccRank         String?

  isNccProfileCompleted Boolean @default(true)
  studentId             String  @unique
  student               Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PhysicalMedicalProfile {
  id String @id @default(cuid())

  height          String?
  weight          String?
  chest           String?
  runningDistance String?
  runningTimeing  String?

  //medical info
  spectacle          String?
  flatFoot           String?
  knockknee          Boolean?
  ChronicDisease     String?
  surgeryHistory     String?
  allergies          String?
  disability         Boolean?
  disabilityDesc     String?
  fitnessCertificate String?

  studentId String  @unique
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum AddressType {
  CURRENT
  PERMANENT
  HOSTEL
  OFFICE
  OTHER
}

model Address {
  id       String      @id @default(cuid())
  type     AddressType @default(PERMANENT)
  city     String
  district String
  state    String
  country  String
  pinCode  String

  landMark String?
  building String?
  street   String?

  // Relation
  studentId String?
  student   Student? @relation(fields: [studentId], references: [id], onDelete: Cascade)

  educationId String?    @unique
  education   Education? @relation(fields: [educationId], references: [id], onDelete: Cascade)

  organizationId String?       @unique
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([studentId]) //indexing for better query
  @@index([city])
  @@index([state])
  @@index([country])
}

enum EducationLevel {
  HIGH_SCHOOL
  DIPLOMA
  BACHELORS
  MASTERS
  PHD
  CERTIFICATION
  OTHER
}

model Education {
  id String @id @default(cuid())

  level EducationLevel

  institutionName   String
  boardOrUniversity String?

  degree       String?
  fieldOfStudy String?

  startDate DateTime
  endDate   DateTime?

  percentage Float?
  cgpa       Float?

  studentId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  address Address?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([studentId])
}

enum HiringType {
  INTERNSHIP
  PARTTME
  FULLTIME
}

model Job {
  id          String    @id @default(cuid())
  title       String
  description String
  jobImage    String?
  skills      String[]
  applyLink   String?
  startDate   DateTime
  endData     DateTime?
  Location    String

  hirignType HiringType?
  ctc        String?
  stipend    String?

  savedBy SavedJob[]

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
}

model SavedJob {
  id String @id @default(cuid())

  studentId String
  jobId     String

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  job     Job     @relation(fields: [jobId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  // Prevent duplicate saves
  @@unique([studentId, jobId])
  @@index([studentId])
  @@index([jobId])
}

model HiringCalender {
  id              String   @id @default(cuid())
  companyName     String
  title           String
  description     String
  salaryRange     String
  hiringMonth     DateTime
  applyLink       String?
  prepairResource String[]

  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BacklistToken {
  id    String @id @default(cuid())
  token String
}

enum NotificationType {
  PERSONAL
  GENERAL
}

model NccBenifit {
  id String @id @default(cuid())

  cirtificate  String
  benifit      String   @db.Text
  Scholarship  String?
  bonusMark    String?
  nccQuota     String?
  scholarships String[]
  isDeleted    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Scholarship {
  id               String   @id @default(cuid())
  name             String
  eligibility      String
  requiredDocument String[]
  amount           String

  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum MentorRequestStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model MentorRequest {
  id String @id @default(cuid())

  note      String @db.Text
  studentId String
  teacherId String

  status MentorRequestStatus @default(PENDING)

  requestedAt DateTime  @default(now())
  respondedAt DateTime?

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacher Admin   @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, teacherId])
}

model Notification {
  id         String           @id @default(cuid())
  title      String
  Descripton String?
  studentId  String?
  type       NotificationType @default(GENERAL)

  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
