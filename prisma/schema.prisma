generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum StudentStatus {
  ACTIVE
  INACTIVE
  BLOCKED
}

enum AdminRole {
  SYSTEM_ADMIN
  TEACHER
}

model Admin {
  id String @id @default(cuid())

  fullName     String
  profileImage String?
  email        String  @unique
  phone        String? @unique
  designation  String?
  verifyToken  String?

  password String

  role AdminRole

  isActive      Boolean @default(true)
  isVerified    Boolean @default(false)
  emailVerifyed Boolean @default(false)

  // Organization
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Soft Delete
  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  @@index([organizationId])
  @@index([role])
}

model Organization {
  id String @id @default(cuid())

  name  String
  email String? @unique
  phone String?

  website String?
  logo    String?

  description String? @db.Text
  isVerified  Boolean @default(false)

  // Relations
  admins  Admin[]
  address Address?

  hiringEvents Job[]

  // Soft Delete
  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SocialLink {
  id        String  @id @default(cuid())
  platform  String
  url       String
  studentId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model Student {
  id String @id @default(cuid())

  // Basic Information
  fullName    String
  email       String    @unique
  phone       String?   @unique
  password    String?
  dateOfBirth DateTime?
  gender      Gender?
  verifyToken String?

  // Profile
  headline     String? // Full Stack Developer
  bio          String? @db.Text
  profileImage String?
  resumeUrl    String?

  educations  Education[]
  socialLinks SocialLink[]
  skills String[]

  // Job Preferences
  preferredRole     String?
  preferredLocation String[]
  expectedSalary    Int?
  willingToRelocate Boolean  @default(false)
  openToRemote      Boolean  @default(true)

  // Account
  status           StudentStatus @default(ACTIVE)
  profileCompleted Boolean       @default(false)
  profileScore     Int           @default(0)

  // Verification
  emailVerified Boolean @default(false)
  phoneVerified Boolean @default(false)

  // Soft Delete
  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  // Audit
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  addresses Address[]
}

enum AddressType {
  CURRENT
  PERMANENT
  HOSTEL
  OFFICE
  OTHER
}

model Address {
  id       String      @id @default(cuid())
  type     AddressType @default(PERMANENT)
  city     String
  district String
  state    String
  country  String
  pinCode  String

  landMark String?
  building String?
  street   String?

  // Relation
  studentId String?
  student   Student? @relation(fields: [studentId], references: [id], onDelete: Cascade)

  educationId String?    @unique
  education   Education? @relation(fields: [educationId], references: [id], onDelete: Cascade)

  organizationId String?       @unique
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([studentId]) //indexing for better query
  @@index([city])
  @@index([state])
  @@index([country])
}

enum EducationLevel {
  HIGH_SCHOOL
  DIPLOMA
  BACHELORS
  MASTERS
  PHD
  CERTIFICATION
  OTHER
}

model Education {
  id String @id @default(cuid())

  level EducationLevel

  institutionName   String
  boardOrUniversity String?

  degree       String?
  fieldOfStudy String?

  startDate DateTime
  endDate   DateTime?

  percentage Float?
  cgpa       Float?

  studentId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  address Address?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([studentId])
}

enum HiringType {
  INTERNSHIP
  PARTTME
  FULLTIME
}

model Job {
  id          String    @id @default(cuid())
  title       String
  description String
  skills      String[]
  applyLink   String?
  startDate   DateTime
  endData     DateTime?
  Location    String

  hirignType HiringType?
  ctc        String?
  stipend    String?

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
}

model HiringCalender {
  id              String   @id @default(cuid())
  companyName     String
  title           String
  description     String
  salaryRange     String
  hiringMonth     DateTime
  applyLink       String?
  prepairResource String[]

  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BacklistToken {
  id    String @id @default(cuid())
  token String
}
